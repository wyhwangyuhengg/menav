---
import { getFaviconFallbackUrl, getFaviconV2Url, isHttpUrl } from '../lib/view-data/view-utils.ts';

const { site = {}, root = {}, name = '', url = '', icon = 'fas fa-link' } = Astro.props;
const faviconUrl = site.faviconUrl || '';
const forceIconMode = site.forceIconMode || '';
const iconsMode = root?.icons?.mode || 'favicon';
const shouldUseFavicon = forceIconMode ? forceIconMode === 'favicon' : iconsMode === 'favicon';
const canUseGeneratedFavicon = shouldUseFavicon && isHttpUrl(url);
const src = faviconUrl || (canUseGeneratedFavicon ? getFaviconV2Url(url, root) : '');
const fallback = canUseGeneratedFavicon ? getFaviconFallbackUrl(url, root) : '';
const onError = fallback
  ? `if (!this.dataset.faviconFallbackTried) { this.dataset.faviconFallbackTried = '1'; this.src = '${fallback}'; return; } this.classList.add('error'); this.previousElementSibling.classList.add('hidden'); this.nextElementSibling.classList.add('visible');`
  : "this.classList.add('error'); this.previousElementSibling.classList.add('hidden'); this.nextElementSibling.classList.add('visible');";
---

<div class="site-card-icon" aria-hidden="true">
  {
    src ? (
      <div class="icon-container">
        <i class="fas fa-circle-notch fa-spin icon-placeholder" aria-hidden="true" />
        <img
          class="favicon-icon"
          src={src}
          alt={`${name} favicon`}
          loading="lazy"
          onload="this.classList.add('loaded'); this.previousElementSibling.classList.add('hidden');"
          onerror={onError}
        />
        <i class:list={[icon, 'icon-fallback']} aria-hidden="true" />
      </div>
    ) : (
      <i class:list={[icon, 'site-icon']} aria-hidden="true" />
    )
  }
</div>
